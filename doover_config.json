{
    "analog_rain_gauge": {
        "name": "analog_rain_gauge",
        "display_name": "Analog Rain Gauge",
        "type": "DEV",
        "visibility": "PUB",
        "allow_many": false,
        "description": "Measure and report rainfall, events and historical activity",
        "long_description": "README.md",
        "depends_on": [
            "platform_interface"
        ],
        "owner_org": "36a22e32-ab81-4a39-b400-869d532a052d",
        "image_name": "ghcr.io/getdoover/analog-rain-gauge:main",
        "container_registry_profile": "88953909-e9c4-4f81-9ec0-56239d4b0a2e",
        "build_args": "--platform linux/amd64,linux/arm64",
        "staging_config": {
            "owner_org_key": "3ab6efaf-0081-420a-9b38-c64e250e69b1",
            "container_registry_profile_key": "d216c926-f465-4ecb-9156-6841762d6606",
            "key": "82053b28-0f65-49ff-b3f4-ba681ffd9bfe"
        },
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "$default",
            "type": "object",
            "properties": {
                "input_pin": {
                    "title": "Input Pin",
                    "x-name": "input_pin",
                    "x-hidden": false,
                    "type": "integer",
                    "x-required": true,
                    "description": "Input pin connected to the rain gauge.",
                    "x-position": 0,
                    "minimum": 0
                },
                "output_pin": {
                    "title": "Output Pin",
                    "x-name": "output_pin",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "(Optional) Output DO output pin connected to the rain gauge.",
                    "default": null,
                    "x-position": 1,
                    "minimum": 0
                },
                "millimeters_per_pulse": {
                    "title": "Millimeters per Pulse",
                    "x-name": "millimeters_per_pulse",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The number of millimeters of rain per pulse from the gauge.",
                    "default": 0.2,
                    "x-position": 2,
                    "minimum": 0
                },
                "event_rainfall_threshold": {
                    "title": "Event Rainfall Threshold",
                    "x-name": "event_rainfall_threshold",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The amount of rainfall that triggers an event (mm).",
                    "default": 1.0,
                    "x-position": 3,
                    "minimum": 0
                },
                "event_completion_duration": {
                    "title": "Event Completion Duration",
                    "x-name": "event_completion_duration",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The numer of hours of no rainfall to consider an event finished.",
                    "default": 24,
                    "x-position": 4,
                    "minimum": 0
                }
            },
            "additionalElements": true,
            "required": [
                "input_pin"
            ]
        },
        "key": "baae5fde-08f6-4620-8ce6-d286f62ab84b",
        "repo_branch": "main",
        "lambda_config": {},
        "owner_org_id": null,
        "container_registry_profile_id": "93955828574386692",
        "id": "144012655370225164",
        "organisation_id": null,
        "code_repo_id": null,
        "export_config_command": null,
        "run_command": null,
        "lambda_arn": null,
        "ui_schema": {
            "displayString": "$config.app().APP_DISPLAY_NAME:string",
            "hidden": "$config.app().hidden:boolean:false:boolean:false",
            "position": "$config.app().position:number:50",
            "icon": null,
            "colour": null,
            "defaultOpen": false,
            "type": "uiApplication",
            "name": "$config.app().APP_KEY",
            "children": {
                "rainfall_chart": {
                    "name": "rainfall_chart",
                    "type": "uiRemoteComponent",
                    "displayString": "Rainfall Chart",
                    "showActivity": true,
                    "componentUrl": "https://getdoover.github.io/analog-rain-gauge/RainfallWidget.js",
                    "position": 51,
                    "hidden": false,
                    "children": {}
                },
                "since_9am": {
                    "name": "since_9am",
                    "type": "uiVariable",
                    "displayString": "Since 9am",
                    "showActivity": true,
                    "position": 52,
                    "hidden": false,
                    "units": "mm",
                    "varType": "float",
                    "currentValue": "$tag.app().since_9am:number:0",
                    "decPrecision": 2
                },
                "since_event_start": {
                    "name": "since_event_start",
                    "type": "uiVariable",
                    "displayString": "Since Event Start",
                    "showActivity": true,
                    "position": 53,
                    "hidden": false,
                    "units": "mm",
                    "varType": "float",
                    "currentValue": "$tag.app().since_event:number:0",
                    "decPrecision": 2
                },
                "total_rainfall": {
                    "name": "total_rainfall",
                    "type": "uiVariable",
                    "displayString": "Total Rainfall",
                    "showActivity": true,
                    "position": 54,
                    "hidden": false,
                    "units": "mm",
                    "varType": "float",
                    "currentValue": "$tag.app().total_rainfall:number:0",
                    "decPrecision": 2
                },
                "rain_intensity": {
                    "name": "rain_intensity",
                    "type": "uiVariable",
                    "displayString": "Rain Intensity",
                    "showActivity": true,
                    "position": 55,
                    "hidden": false,
                    "units": "mm/hr",
                    "varType": "float",
                    "currentValue": "$tag.app().intensity:number:0",
                    "decPrecision": 2
                },
                "event_started": {
                    "name": "event_started",
                    "type": "uiTimestamp",
                    "displayString": "Event Started",
                    "showActivity": true,
                    "position": 56,
                    "hidden": false,
                    "varType": "timestamp",
                    "currentValue": "$tag.app().event_started:number:null"
                },
                "actions": {
                    "name": "actions",
                    "type": "uiSubmodule",
                    "displayString": "Actions",
                    "showActivity": true,
                    "position": 59,
                    "hidden": false,
                    "children": {
                        "set_total_rainfall": {
                            "name": "set_total_rainfall",
                            "type": "uiFloatInput",
                            "displayString": "Set Total Rainfall",
                            "position": 57,
                            "hidden": false,
                            "units": "mm",
                            "requiresConfirm": true,
                            "min": 0
                        },
                        "reset_event": {
                            "name": "reset_event",
                            "type": "uiButton",
                            "displayString": "Reset Event",
                            "position": 58,
                            "hidden": false,
                            "requiresConfirm": true
                        }
                    },
                    "defaultOpen": false
                }
            }
        }
    }
}